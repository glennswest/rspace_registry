# Arguments passed to `rspace-registry serve` by the systemd unit.
# Run `rspace-registry serve --help` for the full flag list.
#
# Defaults: unauthenticated (DO NOT use in production — set --auth or
# --auth-file), single data dir under the systemd StateDirectory.
RSPACE_REGISTRY_ARGS=--listen 0.0.0.0:5000 --data /var/lib/rspace_registry
